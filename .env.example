# 서버 포트
PORT=3000

# 세션 토큰 서명 시크릿(HMAC). 미설정 시 부팅마다 무작위로 생성되어
# 서버 재시작 때 모든 사용자의 신원(=파티 소유권)이 초기화된다.
# 운영에서는 반드시 길고 무작위인 값을 고정 설정할 것(예: openssl rand -hex 32).
SESSION_SECRET=

# 허용할 Origin 목록(콤마 구분). 브라우저 WebSocket/polling 핸드셰이크 모두에 적용된다.
# 미설정 시 안전한 기본값으로 폴백: 요청의 Origin이 서버 자신의 Host와 같을 때만 허용
# (동일 출처 배포가 기본 시나리오). 프론트를 다른 오리진에서 서빙한다면 반드시 설정할 것.
# 예: ALLOWED_ORIGINS=https://lolmatch.onrender.com,https://example.com
ALLOWED_ORIGINS=

# 소켓당 레이트 리밋(고정 윈도). 미설정 시 기본값(20회/10초)을 쓴다.
RATE_LIMIT_MAX=
RATE_LIMIT_WINDOW_MS=
