{
  "name": "lolmatch",
  "version": "0.1.0",
  "private": true,
  "description": "League of Legends 랭크 5포지션 실시간 모집 보드",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "node --import tsx src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "socket.io-client": "^4.8.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
